[Unit]
Description=OxPulse partner-edge bundle (caddy + xray-client + coturn)
Documentation=https://github.com/anatolykoptev/oxpulse-chat/tree/main/deploy/partner-edge
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/etc/oxpulse-partner-edge
EnvironmentFile=-/var/lib/oxpulse-partner-edge/install.env
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
ExecReload=/usr/bin/docker compose up -d --force-recreate
TimeoutStartSec=180
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
